# ══════════════════════════════════════════════════════════════
#  量子认知引擎 — 环境变量模板
#  使用方式：复制本文件为 .env，然后填写实际值
#  注意：.env 已加入 .gitignore，绝对不会提交到 GitHub
# ══════════════════════════════════════════════════════════════

# ── 必填：阿里云 DashScope API Key ───────────────────────────
# 开通地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 可选：Tavily 网络搜索 API Key ────────────────────────────
# 开通地址：https://app.tavily.com/
# 留空则 AI 助手无法搜索最新信息，其他功能正常
TAVILY_API_KEY=

# ── 可选：量子数据 API（后端 Agent 工具）──────────────────────────
# 一次性替换建议：
# 1) QUANTUM_API_BASE_URL 只写网关基础地址（可包含 /datalake/api）
# 2) 下面 PATH 按你的网关实际转发规则改
# 例：QUANTUM_API_BASE_URL=http://47.110.226.140:8080/datalake/api
QUANTUM_API_BASE_URL=
QUANTUM_API_KEY=
QUANTUM_API_PAPERS_PATH=/papers
QUANTUM_API_PAPERS_SEARCH_PATH=/papers/search
QUANTUM_API_PAPERS_SEARCH_METHOD=POST
QUANTUM_API_PAPERS_SORT_BY=year
QUANTUM_API_PAPERS_SORT_ORDER=desc
QUANTUM_API_PAPERS_INCLUDE_STATS=false
QUANTUM_API_PEOPLE_SEARCH_PATH=/people/search
QUANTUM_API_NEWS_PATH=/news
QUANTUM_API_NEWS_SEARCH_PATH=/news/search

# ── 必填：ECS 服务器公网 IP ──────────────────────────────────
# 用于 CORS 配置（让浏览器可以跨域请求后端）
# 例如：ECS_IP=47.110.123.45
ECS_IP=YOUR_ECS_PUBLIC_IP
